SERVER=vpn-mfa.yourcompany.com
USERNAME=<Username>
KEEP_ALIVE_ENDPOINT=internal.yourcompany.com
DYNAMIC_TOKEN=true
PROXY_USER=
PROXY_PASS=

# Authentication mode: "password" (default) or "cookie".
#   password - username + password (+ optional dynamic 2FA token in /vpn/token)
#   cookie   - SAML/SSO (Shibboleth): write a pre-obtained session cookie to
#              /vpn/token; it is fed to openconnect via --cookie-on-stdin.
#              USERNAME/PASSWORD are not used in this mode. See README.
AUTH_MODE=password

# User-Agent openconnect presents to the head-end. Some SSO/SAML gateways only
# switch to the browser (Shibboleth) login flow for a recognised client UA.
USER_AGENT=AnyConnect Windows 4.10.05111
